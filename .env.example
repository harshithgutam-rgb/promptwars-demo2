# VoteBuddy AI Environment Variables

# Server Port
PORT=8080

# Google Gemini API Key (Required - Get free at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Firestore (Optional locally, uses Default Credentials in GCP)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# Optional: Enable Firestore logging (default: false, uses console.log only)
# ENABLE_DB_LOGS=true
